<p id="notice"><%= notice %></p>

<h1>Time Sheets</h1>
<div class="table-responsive">
  <div class="contextual">
    <%= link_to 'New Time Sheet', new_time_sheet_path(parametro: params[:parametro]), class: 'btn btn-sm btn-success', style: 'margin-right: 30px;' %>
  </div>
  <br>
  <br>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th>WEEK</th>
      <th>PROJECT</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% @time_sheets.each do |time_sheet| %>
      <tr>
        <td>
          <% if time_sheet.week.present? %>
            <% current_date = time_sheet.week %> <!-- Obtén la fecha actual -->
            <% next_week_date = current_date + 6.days %> <!-- Suma 7 días a la fecha actual -->
             <%= current_date.strftime('%m/%d/%Y') %> -
             <%= next_week_date.strftime('%m/%d/%Y') %>

        <% else %>
       N/A
          <% end %>
        </td>
        <td><%= time_sheet.address %></td>
        <td><%= link_to 'Show', time_sheet %></td>
        <td><%= link_to 'Edit', edit_time_sheet_path(time_sheet) %></td>
        <td><%= link_to 'Destroy', time_sheet, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
<br>

