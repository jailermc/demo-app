  { lbl:'CHAIN LINK FENCE', ed: :mdescription3,  eq: :mqtysfft3,  ep: :mpricing3,  et: :mtotal3  },
]

oot_rows = [
  { lbl:'HOTEL',        ed: :mdescription17,    eq: :mqtysfft17, ep: :mpricing17,   et: :mtotal17   },
  { lbl:'MOBILIZATION', ed: :mov_pdescription2, eq: :mov_pqty2,  ep: :mov_pricing2, et: :mov_total2 },
  { lbl:'PERDIEM',      ed: :mov_pdescription3, eq: :mov_pqty3,  ep: :mov_pricing3, et: :mov_total3 },
