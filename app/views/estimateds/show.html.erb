%>
<p id="notice"><%= notice %></p>
<%= link_to 'Edit', edit_estimated_path(@estimated) %> |
<%= link_to 'Back', estimateds_path %>
<br><br>
<button id="print-button">Print</button>
<div id="section-to-print">
  <h1 style="font-size:22px;">Demolition Estimating Sheet</h1>

  <table id="principal2" class="table table-bordered table-sm" style="width:90%">
    <thead><tr>
      <% ['','NAME','ADDRESS','DATE','QTY','PER SF / L.F $','STATUS','',''].each do |h| %>
        <th style="background-color:rgba(185,183,183,0.94)"><%= h %></th>
      <% end %>
    </tr></thead>
    <tbody><tr>
      <th></th>
      <td><%= @estimated.name %></td>
      <td><%= @estimated.address %></td>
      <td><%= @estimated.date1.strftime('%m/%d/%Y') %></td>
      <td><%= @estimated.sf %></td>
      <td><%= @estimated.persf %></td>
      <td>
        <% if @estimated.status == 1 %>active
        <% elsif @estimated.status == 2 %>completed
        <% else %>pending
        <% end %>
      </td>
      <td></td><td></td>
    </tr></tbody>
  </table>
  <br>

  <table id="principal" class="table table-bordered table-sm" style="width:90%">
    <thead><tr>
      <th>ACTIVITY</th><th>DESCRIPTION</th><th>QTY MEN</th><th>DAYS</th>
      <th>MEN HRS</th><th>PRICE PER HRS</th><th>TOTAL</th>
    </tr></thead>

    <% (1..12).each do |i| %>
      <% desc_f = (i == 3) ? :adescriptio3 : :"adescription#{i}" %>
      <% hours = @estimated.send(:"ahours#{i}"); ov = @estimated.send(:"over#{i}") %>
      <% atot = @estimated.send(:"atotal#{i}") %>
      <tbody><tr>
        <td class="celda2"><%= @selector[i-1] %></td>
        <td><%= @estimated.send(desc_f) %></td>
        <td><%= @estimated.send(:"aemp#{i}") %></td>
        <td><%= @estimated.send(:"adays#{i}") %></td>
        <td><%= hours == 0 ? "" : hours %> <%= ov == 0 ? "" : ov %></td>
        <td class="celda"><%= @estimated.send(:"apricing#{i}") %></td>
        <td<%= atot == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= atot == 0.0 ? "" : number_to_currency(atot, precision: 2) %></td>
      </tr></tbody>
    <% end %>

    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.atotal, precision: 2) %></td>
    </tr></tbody>

    <!-- EQUIPMENT -->
    <thead><tr>
      <th>EQUIP.</th><th>DESCRIPTION</th><th>QTY</th><th>DAYS</th>
      <th>QTY. GAL.</th><th> GAL. PRICE</th><th>TOTAL</th>
    </tr></thead>
    <tbody><tr>
      <td class="celda2"></td><td></td><td></td><td></td><td></td>
      <th>$ <%= @estimated.fpricing1 %></th><td></td>
    </tr></tbody>

    <% equip_rows.each do |row| %>
      <% n = row[:n]; lbl = row[:lbl] || @estimated.send(:"edefault#{n}") %>
      <% et = @estimated.send(:"etotal#{n}") %>
      <tbody><tr>
        <td class="celda2"><%= lbl %></td>
        <td><%= @estimated.send(:"edescription#{n}") %></td>
        <td><%= @estimated.send(:"eqty#{n}") %></td>
        <td><%= @estimated.send(:"edaywk#{n}") %></td>
        <td><%= @estimated.send(:"eresult#{n}") %></td>
        <td class="celda"><%= @estimated.send(:"epricing#{n}") %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>

    <tbody><tr>
      <td class="celda2"></td><td></td><td></td>
      <th>TOTAL GAL.</th><th><%= @estimated.totalfuel %></th><td></td><td></td>
    </tr></tbody>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td<%= @estimated.etotal == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= @estimated.etotal == 0.0 ? "" : number_to_currency(@estimated.etotal, precision: 2) %></td>
    </tr></tbody>

    <!-- SAW-CUTTING -->
    <thead><tr>
      <th>SAW-CUTTING</th><th>DESCRIPTION</th><th>QTY/SF/LF</th><th>DAYS</th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% [[1,:saw1,:sdescription1,:sqtysflf1,:sdays1,:spricing1,:stotal1],
        [2,:saw2,:sdescription2,:sqtysflf2,:sdays2,:spricing2,:stotal2],
        [3,:saw3,:sdescription3,:sqtysflf3,:sdays3,:spricing3,:stotal3]].each do |_, saw, desc, qty, days, price, tot| %>
      <% et = @estimated.send(tot) %>
      <tbody><tr>
        <td class="celda2"><%= @estimated.send(saw) %></td>
        <td><%= @estimated.send(desc) %></td>
        <td><%= @estimated.send(qty) %></td>
        <td><%= @estimated.send(days) %></td>
        <td></td>
        <td class="celda"><%= @estimated.send(price) %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.stotal, precision: 2) %></td>
    </tr></tbody>

    <!-- MATERIAL -->
    <thead><tr>
      <th>MATERIAL</th><th>DESCRIPTION</th><th>QTY/YDS</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% mat_rows.each do |row| %>
      <% et = @estimated.send(row[:et]) %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(row[:ed]) %></td>
        <td><%= @estimated.send(row[:eq]) %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(row[:ep]) %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.ttotal, precision: 2) %></td>
    </tr></tbody>

    <!-- PERMITS -->
    <thead><tr>
      <th>PERMITS</th><th>DESCRIPTION</th><th>QTY</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% permit_rows.each do |row| %>
      <% n = row[:n]; et = @estimated.send(:"ptotal#{n}"); bg = row[:bg] || '#FFFF00' %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(:"pdescription#{n}") %></td>
        <td><%= @estimated.send(:"pqty#{n}") %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(:"ppricing#{n}") %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #{bg}\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.pptotal, precision: 2) %></td>
    </tr></tbody>

    <!-- EROSION CONTROL -->
    <thead><tr>
      <th>ERROSION CONTROL</th><th>DESCRIPTION</th><th>QTY</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% erosion_rows.each do |row| %>
      <% et = @estimated.send(row[:et]) %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(row[:ed]) %></td>
        <td><%= @estimated.send(row[:eq]) %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(row[:ep]) %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.ec_total, precision: 2) %></td>
    </tr></tbody>

    <!-- TEMP FENCE -->
    <thead><tr>
      <th>TEMP FENCE</th><th>DESCRIPTION</th><th>QTY</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% tf_rows.each do |row| %>
      <% et = @estimated.send(row[:et]) %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(row[:ed]) %></td>
        <td><%= @estimated.send(row[:eq]) %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(row[:ep]) %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.tf_total, precision: 2) %></td>
    </tr></tbody>

    <!-- OUT OF TOWN -->
    <thead><tr>
      <th>OUT OF TOWN</th><th>DESCRIPTION</th><th>QTY</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% oot_rows.each do |row| %>
      <% et = @estimated.send(row[:et]) %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(row[:ed]) %></td>
        <td><%= @estimated.send(row[:eq]) %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(row[:ep]) %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.per_total, precision: 2) %></td>
    </tr></tbody>

    <!-- MISCELLANEOUS -->
    <thead><tr>
      <th>MISCELLANEOUS</th><th>DESCRIPTION</th><th>QTY/SF/FT</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% misc_rows.each do |row| %>
      <% n = row[:n]; et = @estimated.send(:"mtotal#{n}") %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(:"mdescription#{n}") %></td>
        <td><%= @estimated.send(:"mqtysfft#{n}") %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(:"mpricing#{n}") %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <td>TOTAL</td><td></td><td></td><td></td><td></td><td></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.mtotal, precision: 2) %></td>
    </tr></tbody>

    <!-- SUB-CONTRACTORS -->
    <thead><tr>
      <th>SUB C / ALT-</th><th>DESCRIPTION / COMPANY</th><th>QTY/SF/FT</th>
      <th>UNIT.PRICE</th><th></th><th>PROFIT(%)</th><th>TOTAL</th>
    </tr></thead>
    <% (1..3).each do |i| %>
      <% st = @estimated.send(:"subtotal#{i}") %>
      <tbody><tr>
        <td class="celda20"><%= @estimated.send(:"subdefault#{i}") %></td>
        <td><%= @estimated.send(:"subdescription#{i}") %></td>
        <td><%= @estimated.send(:"subqtysfft#{i}") %></td>
        <td><%= @estimated.send(:"subpricing#{i}") %></td>
        <td></td>
        <td><%= @estimated.send(:"subporce#{i}") %> %</td>
        <td style="<%= st == 0.0 ? '' : 'background-color: #FFFF00' %>">
          <%= st == 0.0 ? '' : number_to_currency(st, precision: 2) %>
        </td>
      </tr></tbody>
    <% end %>
    <tbody><tr>
      <tH>TOTAL</tH><th></th><th></th><th></th><th></th><th></th>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.subtotaltotal, precision: 2) %></td>
    </tr></tbody>
    <tr style="height:20px;"></tr>

    <!-- SCRAP -->
    <thead><tr>
      <th>SCRAP</th><th>DESCRIPTION</th><th>QTY/SF/FT</th><th></th>
      <th></th><th>UNIT.PRICE</th><th>TOTAL</th>
    </tr></thead>
    <% scrap_rows.each do |row| %>
      <% n = row[:n]; et = @estimated.send(:"mtotal#{n}") %>
      <tbody><tr>
        <td class="celda2"><%= row[:lbl] %></td>
        <td><%= @estimated.send(:"mdescription#{n}") %></td>
        <td><%= @estimated.send(:"mqtysfft#{n}") %></td>
        <td></td><td></td>
        <td class="celda"><%= @estimated.send(:"mpricing#{n}") %></td>
        <td<%= et == 0.0 ? "" : " style=\"background-color: #FFFF00\"" %>><%= et == 0.0 ? "" : number_to_currency(et, precision: 2) %></td>
      </tr></tbody>
    <% end %>

    <tbody><tr>
      <th style="background-color:rgb(155,255,148)"> SALVAGE</th>
      <td>$ <%= @estimated.mpricing12 %></td>
      <td></td><td></td><td></td><td></td>
      <td><%= @estimated.totalsalvage %></td>
    </tr></tbody>
    <tbody><tr>
      <tH></tH><th></th><th></th><th></th><th></th>
      <th>TOTAL SALVAGE</th>
      <th style="background-color:rgb(155,255,148)"><%= @estimated.salvage %></th>
    </tr></tbody>
    <tr style="height:20px;"></tr>

    <!-- SUMMARY -->
    <tbody><tr>
      <th></th><th></th><th></th><th></th><th></th>
      <th> SUBTOTAL</th>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.subtotal, precision: 2) %></td>
    </tr></tbody>
    <tbody><tr>
      <th></th><th></th><th></th><th></th><th></th>
      <td style="background-color: #b1f3b1">PROFIT %: <%= @estimated.profitporcen %></td>
      <td style="background-color: #FFFF00"><%= number_to_currency(@estimated.profit, precision: 2) %></td>
    </tr></tbody>
    <tbody><tr>
      <th></th><th></th><th></th><th></th><th></th>
      <th> TOTAL </th>
      <th style="background-color: #FFFF00"><%= number_to_currency(@estimated.total, precision: 2) %></th>
    </tr></tbody>
  </table>
</div>
<%= link_to 'Edit', edit_estimated_path(@estimated) %> |
<%= link_to 'Back', estimateds_path %>
<br>
<script>
    document.getElementById("print-button").addEventListener("click", function() {
        let printContents = document.getElementById("section-to-print").innerHTML;
        let originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;
        window.print();
        window.location.reload();
        document.body.innerHTML = originalContents;
    });

    const celdas = document.querySelectorAll(".celda");
    celdas.forEach(celda => {
        if (celda.textContent) {
            celda.style.backgroundColor = "#FFFF00";
        }
    });

    const celdas2 = document.querySelectorAll(".celda2");
    celdas2.forEach(celda2 => {
        if (celda2.textContent) {
            celda2.style.backgroundColor = "#d1e2ff";
        }
    });

    const tabla = document.querySelector('#principal');
    const celdas3 = tabla.getElementsByTagName('td','th');
    for (let i = 0; i < celdas3.length; i++) {
        const texto = celdas3[i].textContent;
        celdas3[i].textContent = texto.toUpperCase();
        celdas3[i].style.fontWeight = 'bold';
    }

    const tabla2 = document.querySelector('#principal2');
    const celdas5 = tabla2.getElementsByTagName('td','th');
    for (let i = 0; i < celdas5.length; i++) {
        const texto = celdas5[i].textContent;
        celdas5[i].textContent = texto.toUpperCase();
        celdas5[i].style.fontWeight = 'bold';
    }

</script>
