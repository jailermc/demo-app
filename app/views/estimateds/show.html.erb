  { lbl:'TURBIDITY CURTIN', ed: :ec_description4, eq: :ec_qty4,   ep: :ec_pricing4, et: :ec_total4  },
  { lbl:'GUTTER BUDDY',     ed: :ec_description5, eq: :ec_qty5,   ep: :ec_pricing5, et: :ec_total5  },
  { lbl:'SOD / HYDRO,SEEDS',ed: :mdescription9,   eq: :mqtysfft9, ep: :mpricing9,   et: :mtotal9    },
