  { n:3,  lbl:'SCISSOR LIF' },
  { n:4,  lbl:'LOADER' },
  { n:5,  lbl:'DUMP TRUCK' },
  { n:6,  lbl:'BOBCAT' },
  { n:12, lbl:'UTILITY TRUCK' },
  { n:7,  lbl:'FLOOR SCRAPER' },
  { n:8,  lbl:'WATER TRUCK' },
