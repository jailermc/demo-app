misc_rows = [
  { lbl:'Asbestos',          n:4  },
  { lbl:'Freon Removal',     n:11 },
  { lbl:'Pump-Out',          n:5  },
  { lbl:'TORCHING',          n:7  },
  { lbl:'TRASH CHUTE',       n:8  },
