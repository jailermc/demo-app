        <tbody><tr>
          <td style="text-align:left;">
            <span style="margin-left:0px;"><b>Name</b>:</span> <%= @cost_sheet.name %>
            <span style="margin-left:80px;"><b>Address</b>:</span> <%= @cost_sheet.address %>
          </td>
          <td></td>
          <td style="text-align:left;">
            <span style="margin-right:0px;"><b>Project Manager:</b></span> <%= @cost_sheet.pmanager %>
            <span style="margin-left:50px;"><b>Email:</b></span> <%= @cost_sheet.pemail %>
            <span style="margin-left:50px;"><b>Cell:</b></span> <%= @cost_sheet.pcell %>
          </td>
          <th></th>
        </tr></tbody>
        <tbody><tr>
          <td> </td><td></td>
          <td style="text-align:left;">
            <span style="margin-left:0px;"><b>Supervisor:</b></span> <%= @cost_sheet.supervisor %>
            <span style="margin-left:85px;"><b>Cell:</b></span> <%= @cost_sheet.scell %>
          </td>
          <th></th>
        </tr></tbody>
        <tr style="height:20px;"></tr>
        <tbody><tr>
          <td> </td><td></td>
          <td style="text-align:left;">
            <span style="margin-left:0px;"><b>Start Date:</b></span>
            <%= @cost_sheet.sdate.present? ? @cost_sheet.sdate.strftime('%m/%d/%Y') : '0/0/0' %>
            <span style="margin-left:22px;"><b>Finish Date:</b></span>
            <%= @cost_sheet.fdate.present? ? @cost_sheet.fdate.strftime('%m/%d/%Y') : '0/0/0' %>
          </td>
          <th></th>
        </tr></tbody>
        <tbody><tr>
          <td> </td><td></td>
          <td style="text-align:left;">
            <span style="margin-left:0px;"><b>NOC:</b></span> <%= @cost_sheet.noc %>
