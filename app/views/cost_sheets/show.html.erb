        <th>PRICE HRS</th><th>TOTAL</th>
        <th>ACTIVITY</th><th>QTY MEN</th><th>DAYS</th><th>MEN HRS</th><th>PRICE HRS</th><th>TOTAL</th>
      </tr></thead>

      <% (1..12).each do |i| %>
        <% desc_f = (i == 3) ? :adescriptio3 : :"adescription#{i}" %>
        <% hours = @estimated.send(:"ahours#{i}"); ov = @estimated.send(:"over#{i}") %>
        <% atot = @estimated.send(:"atotal#{i}"); ctot = @cost_sheet.send(:"atotal#{i}") %>
        <tbody><tr>
          <td class="celda2"><%= @selector1[i-1] %></td>
          <td><%= @estimated.send(desc_f) %></td>
          <td><%= @estimated.send(:"aemp#{i}") %></td>
          <td><%= @estimated.send(:"adays#{i}") %></td>
          <td><%= hours == 0 ? "" : hours %><%= i >= 6 ? (ov == 0 ? "" : " #{ov}") : "" %></td>
          <td><%= @estimated.send(:"apricing#{i}") %></td>
          <td><%= atot == 0.0 ? "" : number_to_currency(atot, precision: 2) %></td>
          <th class="celda2"></th>
          <td><%= instance_variable_get("@max#{i}") %></td>
          <td><%= @dayly_counts[i-1] %></td>
          <td><%= instance_variable_get("@sumhours#{i}") %></td>
          <td><%= @cost_sheet.send(:"apricing#{i}") %></td>
          <td><%= ctot == 0.0 ? "" : number_to_currency(ctot, precision: 2) %></td>
        </tr></tbody>
      <% end %>

      <tbody><tr>
        <td></td><td></td><td></td><td></td><td></td><td></td><td></td>
