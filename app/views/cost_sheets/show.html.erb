<script>
    document.getElementById("print-button").addEventListener("click", function() {
        let printContents = document.getElementById("section-to-print").innerHTML;
        let originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;
        window.print();
        window.location.reload();
        document.body.innerHTML = originalContents;
    });

    var celdas = document.getElementsByClassName("celda2");
    for (var i = 0; i < celdas.length; i++) {
        celdas[i].style.backgroundColor = "#d0e5ff";
        celdas[i].style.fontWeight = "bold";
    }

    const tableHeaders = document.querySelectorAll("thead th");
    for (const header of tableHeaders) {
        header.style.backgroundColor = "rgba(217,213,213,0.94)";
    }
    const tableCells = document.querySelectorAll("td");
    for (const cell of tableCells) {
        if (cell.textContent.trim().length === 0 ||
            isNaN(parseFloat(cell.textContent.replace(/\$|,/g, ''))) ||
            parseFloat(cell.textContent.replace(/\$|,/g, '')) === 0.0) {
            continue;
        }
        if (parseFloat(cell.textContent.replace(/\$|,/g, '')) > 0) {
            cell.style.backgroundColor = "#e5ff6f";
        } else {
            cell.style.backgroundColor = "#ff9797";
        }
    }

    const tableCells2 = document.querySelectorAll("th");
    for (const cell of tableCells2) {
        if (cell.textContent.trim().length === 0 ||
            isNaN(parseFloat(cell.textContent.replace(/\$|,/g, ''))) ||
            parseFloat(cell.textContent.replace(/\$|,/g, '')) === 0.0) {
            continue;
        }
        if (parseFloat(cell.textContent.replace(/\$|,/g, '')) > 0) {
            cell.style.backgroundColor = "#75ff6b";
        } else {
            cell.style.backgroundColor = "#ff9797";
        }
    }

    var celdas10 = document.getElementsByClassName("celda2");
    for (var i = 0; i < celdas10.length; i++) {
        celdas[i].style.backgroundColor = "#d2ddf3";
        celdas[i].style.fontWeight = "bold";
    }

    function compareQty(base) {
        var v1 = parseFloat(document.getElementById(base + '1').innerHTML);
        var v2 = parseFloat(document.getElementById(base + '2').innerHTML);
        if (v2 === 0) {
            document.getElementById(base + '2').style.clear = 'yellow';
        } else if (isNaN(v1)) {
            document.getElementById(base + '2').style.backgroundColor = '#ff9797';
            document.getElementById(base + '3').style.backgroundColor = '#ff9797';
        } else if (v1 < v2) {
            document.getElementById(base + '2').style.backgroundColor = '#ff9797';
            document.getElementById(base + '3').style.backgroundColor = '#ff9797';
        } else {
            document.getElementById(base + '2').style.backgroundColor = '#75ff6b';
            document.getElementById(base + '3').style.backgroundColor = '#75ff6b';
        }
    }
    ['trash','tree','concrete','rebar','asphalt','fill','rock'].forEach(compareQty);
</script>
