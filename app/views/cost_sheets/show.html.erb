%>
<%= link_to 'Edit', edit_cost_sheet_path(@cost_sheet) %> |
<%= link_to 'Back', cost_sheets_path %>
<br><br>
<button id="print-button">Print</button>
<br>
<div>
  <div id="section-to-print">
    <h3><%= @estimated.address %></h3>
    <div id="table">
