            <%= @cost_sheet.nocdate.present? ? @cost_sheet.nocdate.strftime('%m/%d/%Y') : '0/0/0' %>
            <span style="margin-left:50px;"><b>Exp:</b></span>
            <%= @cost_sheet.nocedate.present? ? @cost_sheet.nocedate.strftime('%m/%d/%Y') : '0/0/0' %>
          </td>
          <th></th>
        </tr></tbody>
        <tbody><tr>
          <td> </td><td></td>
          <td style="text-align:left;">
            <span style="margin-left:0px;"><b>NTO:</b></span> <%= @cost_sheet.nto %>
            <span style="margin-left:85px;"><b>Date:</b></span>
