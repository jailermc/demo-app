<!DOCTYPE html>
<html>
  <head>
    <title>Thunder Demolition</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="<%= root_path %>">
          Thunder Demolition
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to 'Estimates', estimateds_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Cost Sheets', cost_sheets_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Daily Logs', dailylogs_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Change Orders', change_orders_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'RFIs', rfis_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Employees', employees_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'LEED', leeds_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Time Sheets', time_sheets_path, class: 'nav-link' %>
            </li>
          </ul>
          <ul class="navbar-nav">
            <% if user_signed_in? %>
              <li class="nav-item">
                <span class="nav-link text-light"><%= current_user.email %></span>
              </li>
              <li class="nav-item">
                <%= link_to 'Sign out', destroy_user_session_path, method: :delete, class: 'nav-link' %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to 'Sign in', new_user_session_path, class: 'nav-link' %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container-fluid mt-3">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
