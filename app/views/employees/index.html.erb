<p id="notice"><%= notice %></p>

<h1>Employees</h1>
<div class="contextual">
  <%= link_to 'New Employee', new_employee_path, class: 'btn btn-sm btn-success', style: 'margin-right: 30px;' %>
</div>
<table class="table table-bordered table-sm">
  <thead>
    <tr>
      <th>Name</th>
      <th>Last Name</th>
      <th>Function</th>
      <th>Active</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% @employees.each do |employee| %>
      <tr>
        <td><%= employee.name %></td>
        <td><%= employee.lastname %></td>
        <td><%= case employee.function
                when 1 then 'Labor'
                when 2 then 'Operator'
                when 3 then 'Supervisor'
                when 4 then 'Driver'
                else 'N/A'
                end %></td>
        <td><%= employee.active1 == 1 ? 'YES' : 'NO' %></td>
        <td colspan="3"></td>
        <td><%= link_to 'Show', employee %></td>
        <td><%= link_to 'Edit', edit_employee_path(employee) %></td>
        <td><%= link_to 'Destroy', employee, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<br>

